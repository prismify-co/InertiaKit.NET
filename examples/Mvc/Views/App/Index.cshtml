@{
    Layout = null;
    var pageJson = Context.Items["InertiaPage"] as string ?? "{}";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>InertiaKit Vue MVC</title>
    <link rel="stylesheet" href="/build/app.css" />
</head>
<body>
    <div id="app"></div>
    <script type="application/json" id="app-data">@Html.Raw(pageJson)</script>
    <script type="module" src="/build/app.js"></script>
</body>
</html>
